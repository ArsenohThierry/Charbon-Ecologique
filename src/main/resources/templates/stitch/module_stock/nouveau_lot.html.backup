<!DOCTYPE html><html lang="fr"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Charbon Vert - Saisir un nouveau lot</title>
<!-- Tailwind CSS v3 CDN with Plugins -->
