<!-- Google Font: Libre Caslon Text -->
<link href="https://fonts.googleapis.com/css2?family=Libre+Caslon+Text:wght@400;700&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet">
<script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              DEFAULT: '#1b3c2e',
              dark: '#142d22',
              light: '#3d5c4d',
              accent: '#e69a4c' // From the active menu item in the image
            },
            surface: {
              DEFAULT: '#f3fbf6',
              dim: '#d4dcd6',
              container: '#ffffff'
            }
          },
          fontFamily: {
            serif: ['Libre Caslon Text', 'serif'],
            sans: ['Inter', 'sans-serif'],
          },
          borderRadius: {
            'eight': '8px',
          }
        }
      }
    }
  </script>
<style data-purpose="layout">
    body {
      background-color: #f3fbf6;
      font-family: 'Inter', sans-serif;
    }
    h1, h2, .font-serif {
      font-family: 'Libre Caslon Text', serif;
    }
    /* Custom scrollbar for sidebar */
    .sidebar-scroll::-webkit-scrollbar {
      width: 4px;
    }
    .sidebar-scroll::-webkit-scrollbar-thumb {
      background: #3d5c4d;
      border-radius: 2px;
    }
  </style>
<style data-purpose="navigation-styling">
    .nav-item {
      display: flex;
      align-items: center;
      padding: 0.75rem 1rem;
      color: #d1d5db;
      font-size: 0.875rem;
      transition: all 0.2s;
    }
    .nav-item:hover {
      background-color: rgba(255, 255, 255, 0.05);
      color: white;
    }
    .nav-item.active {
      background-color: #e69a4c;
      color: #1b3c2e;
      font-weight: 600;
      border-radius: 0.5rem;
    }
    .nav-group-title {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #9ca3af;
      padding: 1.5rem 1rem 0.5rem;
    }
    .sub-nav-item {
      padding-left: 2.5rem;
      padding-right: 1rem;
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
      display: flex;
      align-items: center;
      font-size: 0.8125rem;
      color: #9ca3af;
    }
    .sub-nav-item.active {
      color: #e69a4c;
    }
  </style>
</head>
<body class="flex h-screen overflow-hidden">
<!-- BEGIN: LeftSidebar -->
<aside class="w-64 bg-brand text-white flex flex-col h-full shrink-0">
<div class="p-6 flex items-center gap-3" data-purpose="brand-logo">
<div class="w-10 h-10 bg-brand-accent rounded-full flex items-center justify-center text-brand font-bold">
<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<div>
<h2 class="text-lg font-bold leading-tight">Charbon Vert</h2>
<p class="text-[10px] text-gray-400">Gestionnaire de stock</p>
</div>
</div>
<nav class="flex-1 overflow-y-auto sidebar-scroll px-3 pb-4 space-y-1">
<a class="nav-item" href="#">
<svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
        Tableau de bord
      </a>
<div><div class="nav-item flex justify-between cursor-pointer"><div class="flex items-center"><svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Approvisionnement &amp; mat...</div><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div><div class="pb-2"><a class="sub-nav-item" href="#"><svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Nouvel achat</a><a class="sub-nav-item" href="#"><svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6h16M4 10h16M4 14h16M4 18h16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Liste des achats</a></div></div>
<div class="space-y-1">
<div class="nav-item flex justify-between cursor-pointer">
<div class="flex items-center">
<svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            Lots de production
          </div>
<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
</div>
<div class="pb-2">
<a class="sub-nav-item active font-semibold bg-brand-accent rounded-md text-brand my-1 py-3" href="#">
<svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            Saisir un nouveau lot
          </a>
<a class="sub-nav-item" href="#">
<svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6h16M4 10h16M4 14h16M4 18h16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            Liste des lots
          </a>
<a class="sub-nav-item" href="#">
<svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            Historique des statuts
          </a>
</div>
</div>
<div>
<div class="nav-item flex justify-between cursor-pointer">
<div class="flex items-center">
<svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
            Généralités stocks
          </div>
<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
</div>
<div class="pb-2"><a class="sub-nav-item" href="#"><svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Inventaire actuel</a><a class="sub-nav-item" href="#"><svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Mouvements</a></div></div>
<div><div class="nav-item flex justify-between cursor-pointer"><div class="flex items-center"><svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Ventes / Commandes</div><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div><div class="pb-2"><a class="sub-nav-item" href="#"><svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Nouvelle vente</a><a class="sub-nav-item" href="#"><svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Liste des ventes</a></div></div>
<div><div class="nav-item flex justify-between cursor-pointer"><div class="flex items-center"><svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 17v-2a4 4 0 10-8 0v2a2 2 0 002 2h4a2 2 0 002-2zm3-9a9 9 0 1118 0 9 9 0 01-18 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Rapports</div><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg></div><div class="pb-2"><a class="sub-nav-item" href="#"><svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Production</a><a class="sub-nav-item" href="#"><svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>Finances</a></div></div>
</nav>
<div class="mt-auto p-4 border-t border-brand-light">
<a class="nav-item px-2" href="#">
<svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>
        Changer de rôle
      </a>
</div>
</aside>
<!-- END: LeftSidebar -->
<!-- BEGIN: MainContent -->
<main class="flex-1 overflow-y-auto flex flex-col">
<!-- BEGIN: Header -->
<header class="h-16 px-8 border-b border-gray-200 bg-white flex items-center justify-between" data-purpose="main-header">
<div data-purpose="page-title">
<h1 class="text-xl font-bold text-brand">Gestionnaire de stock</h1>
<p class="text-xs text-gray-500 uppercase tracking-wide">Approvisionnement, lots &amp; inventaire</p>
</div>
<div class="flex items-center gap-4" data-purpose="header-actions">
<div class="bg-brand/5 px-4 py-1 rounded-full text-xs text-brand font-medium border border-brand/10">
          Maquette · données fictives
        </div>
<div class="w-8 h-8 rounded-full bg-brand text-white flex items-center justify-center font-bold text-sm">
          N
        </div>
</div>
</header>
<!-- END: Header -->
<div class="p-12 max-w-5xl mx-auto w-full">
<!-- BEGIN: ContentTitle -->
<div class="mb-10" data-purpose="form-intro">
<h2 class="text-4xl font-serif text-brand mb-2">Saisir un nouveau lot</h2>
<p class="text-gray-500">Créer un lot de production. Le statut initial est « Préparation ».</p>
</div>
<!-- END: ContentTitle -->
<!-- BEGIN: FormCard -->
<section class="bg-white rounded-eight shadow-sm border border-gray-100 p-8" data-purpose="form-container">
<form class="space-y-8">
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
<!-- Matière première -->
<div class="flex flex-col gap-2">
<label class="text-sm font-semibold text-gray-700" for="matiere_premiere">Matière première</label>
<select class="rounded-eight border-gray-300 focus:border-brand focus:ring-brand h-11 px-4 text-gray-600 bg-white" id="matiere_premiere"><option value="">Sélectionner...</option><option value="balle_riz">Balle de riz</option><option value="sciure">Sciure de bois</option><option value="epluchures_manioc">Épluchures de manioc</option><option value="residus_mixtes">Résidus mixtes</option><option value="feuilles_seches">Feuilles sèches</option></select>
</div>
<!-- Quantité -->
<div class="flex flex-col gap-2">
<label class="text-sm font-semibold text-gray-700" for="quantite">Quantité (kg)</label>
<input class="rounded-eight border-gray-300 focus:border-brand focus:ring-brand h-11 px-4 text-gray-800" id="quantite" placeholder="120" type="number" value="120">
</div>
<!-- Liant utilisé -->
<div class="flex flex-col gap-2">
<label class="text-sm font-semibold text-gray-700" for="liant">Liant utilisé</label>
<select class="rounded-eight border-gray-300 focus:border-brand focus:ring-brand h-11 px-4 text-gray-600 bg-white" id="liant"><option value="">Sélectionner...</option><option value="argile">Argile (liant)</option><option value="amidon">Amidon de maïs</option><option value="fecule_manioc">Fécule de manioc</option><option value="sans_liant">Sans liant</option></select>
</div>
<!-- Date de démarrage -->
<div class="flex flex-col gap-2 relative">
<label class="text-sm font-semibold text-gray-700" for="date_demarrage">Date de démarrage</label>
<input class="rounded-eight border-gray-300 focus:border-brand focus:ring-brand h-11 px-4 text-gray-400" id="date_demarrage" placeholder="jj / mm / aaaa" type="text">
<div class="absolute bottom-3 right-3 text-gray-400 pointer-events-none">
<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
</div>
<!-- Responsable -->
<div class="flex flex-col gap-2 col-span-1">
<label class="text-sm font-semibold text-gray-700" for="responsable">Responsable</label>
<input class="rounded-eight border-gray-300 focus:border-brand focus:ring-brand h-11 px-4 text-gray-800" id="responsable" type="text" value="Nomena">
</div>
</div>
<!-- BEGIN: FormActions -->
<div class="pt-6 flex flex-wrap items-center gap-4" data-purpose="form-actions">
<button class="bg-brand hover:bg-brand-dark text-white px-8 py-2.5 rounded-eight font-medium transition-colors" type="submit">
              Créer le lot
            </button>
<button class="bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 px-8 py-2.5 rounded-eight font-medium transition-colors" type="button">
              Annuler
            </button>
<p class="text-xs text-gray-500 ml-2">
              Une nouvelle production sera ajoutée automatiquement.
            </p>
</div>
<!-- END: FormActions -->
</form>
</section>
<!-- END: FormCard -->
</div>
</main>
<!-- END: MainContent -->




</body></html>